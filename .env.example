# ─── Proxy server ─────────────────────────────────────────────────────────────
PORT=4000

# ─── Remote Ollama URL ────────────────────────────────────────────────────────
# Your RunPod / remote host URL (no trailing slash)
OLLAMA_BASE_URL=https://your-runpod-id-11434.proxy.runpod.net

# ─── Default model ────────────────────────────────────────────────────────────
# Used when Claude Code sends a claude-* model name and no alias exists.
DEFAULT_MODEL=mistral

# ─── Model alias map (optional JSON) ─────────────────────────────────────────
# Map claude model names → ollama model names.
# MODEL_MAP={"claude-3-opus-20240229":"mixtral","claude-3-sonnet-20240229":"mistral","claude-3-haiku-20240307":"llama3.2"}

# ─── Streaming ────────────────────────────────────────────────────────────────
ENABLE_STREAMING=true

# ─── Timeout ──────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=120000

# ─── Log level ────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
